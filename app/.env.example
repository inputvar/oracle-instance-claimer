# OCI Configuration
# Get these values from your OCI Account > API Keys > Add API Key
OCI_REGION=ap-mumbai-1
OCI_USER_ID=ocid1.user.oc1..aaaaaaaaaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_TENANCY_ID=ocid1.tenancy.oc1..aaaaaaaaaaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_KEY_FINGERPRINT=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99

# Path to your OCI private key file (absolute path or URL)
# Download from Oracle Cloud Console > Identity > Users > API Keys
OCI_PRIVATE_KEY_FILENAME=/path/to/your/oracleidentitycloudservice_xxxxxxxx.pem

# OCI Network Configuration
OCI_SUBNET_ID=ocid1.subnet.oc1.ap-mumbai-1.aaaaaaaaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_IMAGE_ID=ocid1.image.oc1.ap-mumbai-1.aaaaaaaaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instance Configuration
# Always free ARM: 1,2,3,4. Always free AMD x64: 1
OCI_OCPUS=2

# Always free ARM: 6,12,18,24. NB! Oracle Linux Cloud Developer Image requires minimum 8. Always free AMD x64: 1
OCI_MEMORY_IN_GBS=12

# VM.Standard.A1.Flex for ARM or VM.Standard.E2.1.Micro for AMD x64 (Always Free)
OCI_SHAPE=VM.Standard.A1.Flex

# Maximum number of instances to maintain
OCI_MAX_INSTANCES=1

# SSH public key for instance access (from ~/.ssh/id_rsa.pub or similar)
# No newlines allowed - put entire key inside quotes
OCI_SSH_PUBLIC_KEY="ssh-rsa AAAAB3NzaC1yc2EAAAADAQABA... your@example.com"

# Availability Domain (optional for ARM, required for AMD)
# Get from: Oracle Cloud > Compute > Instances > Availability Domain column
OCI_AVAILABILITY_DOMAIN=iZcM:AP-MUMBAI-1-AD-1

# Cache availability domains on first load
CACHE_AVAILABILITY_DOMAINS=1

# Rate Limiting
# Wait time in seconds when hitting "Too Many Requests" (429) error
TOO_MANY_REQUESTS_TIME_WAIT=600

# Email Notifications (Gmail SMTP)
# Use Gmail App Password, not your main password
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
NOTIFY_EMAIL=notification-email@example.com
